-- =============================================================================
--  mylang.parse — MyLang test language for ParseLang framework validation
--
--  MyLang is a small imperative language designed to exercise every major
--  feature of the ParseLang framework:
--
--    Lexer:    keywords, operators, strings, comments, structural, types,
--              literals, typemap
--    Grammar:  registerLiterals, binaryop, prefix, infix, statement
--    Analysis: semantic (scope, declare, lookup, error on undeclared use)
--    CodeGen:  emit (program root, all stmts, all exprs), helper functions,
--              pipeline configuration (setPlatform, setBuildMode)
--
--  Sample program (hello.ml):
--
--    func add(a: int, b: int) -> int
--      return a + b;
--    end
--
--    var x: int := 10;
--    var msg: string := "hello";
--
--    if x > 5 then
--      print(add(x, 32));
--    else
--      print(0);
--    end
--
--    while x > 0 do
--      x := x - 1;
--    end
--
-- =============================================================================

language MyLang;

-- ---------------------------------------------------------------------------
-- KEYWORDS
-- ---------------------------------------------------------------------------

keywords casesensitive
  'var'    -> 'keyword.var';
  'func'   -> 'keyword.func';
  'return' -> 'keyword.return';
  'if'     -> 'keyword.if';
  'then'   -> 'keyword.then';
  'else'   -> 'keyword.else';
  'while'  -> 'keyword.while';
  'do'     -> 'keyword.do';
  'end'    -> 'keyword.end';
  'print'  -> 'keyword.print';
  'true'   -> 'keyword.true';
  'false'  -> 'keyword.false';
  'nil'      -> 'keyword.nil';
  'platform'  -> 'keyword.platform';
  'buildmode' -> 'keyword.buildmode';
  'optimize'  -> 'keyword.optimize';
  'subsystem' -> 'keyword.subsystem';
  'viEnabled'     -> 'keyword.viEnabled';
  'viExeIcon'     -> 'keyword.viExeIcon';
  'viMajor'       -> 'keyword.viMajor';
  'viMinor'       -> 'keyword.viMinor';
  'viPatch'       -> 'keyword.viPatch';
  'viProductName' -> 'keyword.viProductName';
  'viDescription' -> 'keyword.viDescription';
  'viFilename'    -> 'keyword.viFilename';
  'viCompanyName' -> 'keyword.viCompanyName';
  'viCopyright'   -> 'keyword.viCopyright';
end

-- ---------------------------------------------------------------------------
-- OPERATORS
-- Longer operators listed first to guarantee longest-match.
-- ---------------------------------------------------------------------------

operators
  ':=' -> 'op.assign';
  '<>' -> 'op.neq';
  '<=' -> 'op.lte';
  '>=' -> 'op.gte';
  '->' -> 'op.arrow';
  '+'  -> 'op.plus';
  '-'  -> 'op.minus';
  '*'  -> 'op.star';
  '/'  -> 'op.slash';
  '%'  -> 'op.percent';
  '='  -> 'op.eq';
  '<'  -> 'op.lt';
  '>'  -> 'op.gt';
  '('  -> 'delimiter.lparen';
  ')'  -> 'delimiter.rparen';
  ','  -> 'delimiter.comma';
  ':'  -> 'delimiter.colon';
  ';'  -> 'delimiter.semicolon';
end

-- ---------------------------------------------------------------------------
-- STRING STYLES
-- ---------------------------------------------------------------------------

strings
  '"' '"' -> 'literal.string' escape true;
end

-- ---------------------------------------------------------------------------
-- COMMENTS
-- ---------------------------------------------------------------------------

comments
  line '--';
end

-- ---------------------------------------------------------------------------
-- STRUCTURAL
-- ---------------------------------------------------------------------------

structural
  terminator 'delimiter.semicolon';
  blockclose 'keyword.end';
end

-- ---------------------------------------------------------------------------
-- TYPES
-- ---------------------------------------------------------------------------

types
  'int'    -> 'type.int';
  'string' -> 'type.string';
  'bool'   -> 'type.bool';
  'void'   -> 'type.void';
end

-- ---------------------------------------------------------------------------
-- LITERALS — maps AST node kinds to type kinds for type inference
-- ---------------------------------------------------------------------------

literals
  'literal.integer' -> 'type.int';
  'literal.string'  -> 'type.string';
  'expr.bool'       -> 'type.bool';
end

-- ---------------------------------------------------------------------------
-- TYPE MAP — maps type kind strings to C++23 types
-- ---------------------------------------------------------------------------

typemap
  'type.int'    -> 'int64_t';
  'type.string' -> 'std::string';
  'type.bool'   -> 'bool';
  'type.void'   -> 'void';
end

-- ---------------------------------------------------------------------------
-- REGISTER BUILT-IN LITERAL PREFIX HANDLERS
-- Handles: integer, real, string tokens automatically.
-- ---------------------------------------------------------------------------

registerLiterals;

-- ---------------------------------------------------------------------------
-- BINARY OPERATORS — shorthand registration (parse + emit in one line)
-- ---------------------------------------------------------------------------

binaryop 'op.plus'    power 20 op '+';
binaryop 'op.minus'   power 20 op '-';
binaryop 'op.star'    power 30 op '*';
binaryop 'op.slash'   power 30 op '/';
binaryop 'op.percent' power 30 op '%';
binaryop 'op.eq'      power 10 op '==';
binaryop 'op.neq'     power 10 op '!=';
binaryop 'op.lt'      power 10 op '<';
binaryop 'op.gt'      power 10 op '>';
binaryop 'op.lte'     power 10 op '<=';
binaryop 'op.gte'     power 10 op '>=';

-- ---------------------------------------------------------------------------
-- PREFIX RULES
-- ---------------------------------------------------------------------------

-- Grouped expression:  ( expr )
prefix 'delimiter.lparen' as 'expr.grouped'
  parse
    consume();
    result := createNode();
    addChild(result, parseExpr(0));
    expect('delimiter.rparen');
  end
end

-- Unary minus:  -expr
prefix 'op.minus' as 'expr.negate'
  parse
    result := createNode();
    consume();
    addChild(result, parseExpr(50));
  end
end

-- Boolean true literal
prefix 'keyword.true' as 'expr.bool'
  parse
    result := createNode();
    setAttr(result, 'bool.value', 'true');
    consume();
  end
end

-- Boolean false literal
prefix 'keyword.false' as 'expr.bool'
  parse
    result := createNode();
    setAttr(result, 'bool.value', 'false');
    consume();
  end
end

-- Nil literal
prefix 'keyword.nil' as 'expr.nil'
  parse
    result := createNode();
    consume();
  end
end

-- Identifier: variable reference or start of a call
-- The call is handled by the infix rule on '(' below.
prefix 'identifier' as 'expr.ident'
  parse
    result := createNode();
    setAttr(result, 'ident.name', current().text);
    consume();
  end
end

-- ---------------------------------------------------------------------------
-- INFIX RULES
-- ---------------------------------------------------------------------------

-- Function call:  ident( arg, arg, ... )
-- Binding power 80 — tighter than any binary operator.
infix left 'delimiter.lparen' power 80 as 'expr.call'
  parse
    result := createNode();
    -- 'left' is the expr.ident node holding the function name
    setAttr(result, 'call.name', getAttr(left, 'ident.name'));
    consume();   -- consume '('
    -- parse zero or more comma-separated arguments
    if not check('delimiter.rparen') then
      addChild(result, parseExpr(0));
      while match('delimiter.comma') do
        addChild(result, parseExpr(0));
      end
    end
    expect('delimiter.rparen');
  end
end

-- ---------------------------------------------------------------------------
-- STATEMENT RULES
-- ---------------------------------------------------------------------------

-- var x: type := expr ;
statement 'keyword.var' as 'stmt.var_decl'
  parse
    result := createNode();
    consume();   -- 'var'
    setAttr(result, 'decl.name', current().text);
    consume();   -- identifier
    expect('delimiter.colon');
    setAttr(result, 'decl.type_text', current().text);
    consume();   -- type keyword
    expect('op.assign');
    addChild(result, parseExpr(0));  -- initialiser
    expect('delimiter.semicolon');
  end
end

-- Assignment:  x := expr ;
-- Also handles bare expression statements (e.g. function calls as statements).
-- We check for ':=' to distinguish from a bare expr-statement.
statement 'identifier' as 'stmt.assign'
  parse
    -- Capture the identifier name first, then create only the node we need.
    -- Creating result unconditionally and then overwriting it would orphan the
    -- first node and cause a memory leak.
    name := current().text;
    consume();   -- identifier
    if check('op.assign') then
      consume();   -- ':='
      result := createNode('stmt.assign');
      setAttr(result, 'assign.target', name);
      addChild(result, parseExpr(0));
      expect('delimiter.semicolon');
    else
      -- bare expression statement (e.g. a function call): build call manually.
      expect('delimiter.lparen');
      callNode := createNode('expr.call');
      setAttr(callNode, 'call.name', name);
      if not check('delimiter.rparen') then
        addChild(callNode, parseExpr(0));
        while match('delimiter.comma') do
          addChild(callNode, parseExpr(0));
        end
      end
      expect('delimiter.rparen');
      expect('delimiter.semicolon');
      result := createNode('stmt.expr_stmt');
      addChild(result, callNode);
    end
  end
end

-- print( expr ) ;
statement 'keyword.print' as 'stmt.print'
  parse
    result := createNode();
    consume();   -- 'print'
    expect('delimiter.lparen');
    addChild(result, parseExpr(0));
    expect('delimiter.rparen');
    expect('delimiter.semicolon');
  end
end

-- if expr then stmts [else stmts] end
statement 'keyword.if' as 'stmt.if'
  parse
    result := createNode();
    consume();   -- 'if'
    addChild(result, parseExpr(0));   -- condition (child 0)
    expect('keyword.then');
    -- then-block: parse statements until 'else' or 'end'
    thenBlock := createNode('stmt.block');
    while not check('keyword.else') and not check('keyword.end') do
      addChild(thenBlock, parseStmt());
    end
    addChild(result, thenBlock);     -- then-block (child 1)
    -- optional else
    if match('keyword.else') then
      elseBlock := createNode('stmt.block');
      while not check('keyword.end') do
        addChild(elseBlock, parseStmt());
      end
      addChild(result, elseBlock);   -- else-block (child 2)
    end
    expect('keyword.end');
  end
end

-- while expr do stmts end
statement 'keyword.while' as 'stmt.while'
  parse
    result := createNode();
    consume();   -- 'while'
    addChild(result, parseExpr(0));   -- condition (child 0)
    expect('keyword.do');
    -- body: parse statements until 'end'
    body := createNode('stmt.block');
    while not check('keyword.end') do
      addChild(body, parseStmt());
    end
    addChild(result, body);          -- body (child 1)
    expect('keyword.end');
  end
end

-- return [expr] ;
statement 'keyword.return' as 'stmt.return'
  parse
    result := createNode();
    consume();   -- 'return'
    if not check('delimiter.semicolon') then
      addChild(result, parseExpr(0));
    end
    expect('delimiter.semicolon');
  end
end

-- func name( params ) [-> type] stmts end
statement 'keyword.func' as 'stmt.func_decl'
  parse
    result := createNode();
    consume();   -- 'func'
    setAttr(result, 'func.name', current().text);
    consume();   -- function name identifier
    expect('delimiter.lparen');
    -- parameter list
    while not check('delimiter.rparen') do
      param := createNode('stmt.param');
      setAttr(param, 'param.name', current().text);
      consume();   -- param name
      expect('delimiter.colon');
      setAttr(param, 'param.type_text', current().text);
      consume();   -- param type
      addChild(result, param);
      if not check('delimiter.rparen') then
        expect('delimiter.comma');
      end
    end
    expect('delimiter.rparen');
    -- optional return type
    if match('op.arrow') then
      setAttr(result, 'func.return_type_text', current().text);
      consume();
    else
      setAttr(result, 'func.return_type_text', 'void');
    end
    -- body: parse statements until 'end'
    funcBody := createNode('stmt.block');
    while not check('keyword.end') do
      addChild(funcBody, parseStmt());
    end
    addChild(result, funcBody);
    expect('keyword.end');
  end
end

-- Pipeline configuration statements — set at source level, override Delphi defaults

statement 'keyword.platform' as 'stmt.set_platform'
  parse
    result := createNode();
    consume();   -- 'platform'
    setAttr(result, 'pipeline.value', current().text);
    consume();   -- value identifier
    expect('delimiter.semicolon');
  end
end

statement 'keyword.buildmode' as 'stmt.set_buildmode'
  parse
    result := createNode();
    consume();   -- 'buildmode'
    setAttr(result, 'pipeline.value', current().text);
    consume();   -- value identifier
    expect('delimiter.semicolon');
  end
end

statement 'keyword.optimize' as 'stmt.set_optimize'
  parse
    result := createNode();
    consume();   -- 'optimize'
    setAttr(result, 'pipeline.value', current().text);
    consume();   -- value identifier
    expect('delimiter.semicolon');
  end
end

statement 'keyword.subsystem' as 'stmt.set_subsystem'
  parse
    result := createNode();
    consume();   -- 'subsystem'
    setAttr(result, 'pipeline.value', current().text);
    consume();   -- value identifier
    expect('delimiter.semicolon');
  end
end

-- Version info configuration statements

statement 'keyword.viEnabled' as 'stmt.vi_enabled'
  parse
    result := createNode();
    consume();   -- 'viEnabled'
    setAttr(result, 'vi.value', current().text);
    consume();   -- true/false identifier
    expect('delimiter.semicolon');
  end
end

statement 'keyword.viExeIcon' as 'stmt.vi_exeicon'
  parse
    result := createNode();
    consume();   -- 'viExeIcon'
    raw := current().text;
    setAttr(result, 'vi.value', substr(raw, 2, len(raw) - 2));
    consume();   -- string value
    expect('delimiter.semicolon');
  end
end

statement 'keyword.viMajor' as 'stmt.vi_major'
  parse
    result := createNode();
    consume();   -- 'viMajor'
    setAttr(result, 'vi.value', current().text);
    consume();   -- integer value
    expect('delimiter.semicolon');
  end
end

statement 'keyword.viMinor' as 'stmt.vi_minor'
  parse
    result := createNode();
    consume();   -- 'viMinor'
    setAttr(result, 'vi.value', current().text);
    consume();   -- integer value
    expect('delimiter.semicolon');
  end
end

statement 'keyword.viPatch' as 'stmt.vi_patch'
  parse
    result := createNode();
    consume();   -- 'viPatch'
    setAttr(result, 'vi.value', current().text);
    consume();   -- integer value
    expect('delimiter.semicolon');
  end
end

statement 'keyword.viProductName' as 'stmt.vi_productname'
  parse
    result := createNode();
    consume();   -- 'viProductName'
    raw := current().text;
    setAttr(result, 'vi.value', substr(raw, 2, len(raw) - 2));
    consume();   -- string value
    expect('delimiter.semicolon');
  end
end

statement 'keyword.viDescription' as 'stmt.vi_description'
  parse
    result := createNode();
    consume();   -- 'viDescription'
    raw := current().text;
    setAttr(result, 'vi.value', substr(raw, 2, len(raw) - 2));
    consume();   -- string value
    expect('delimiter.semicolon');
  end
end

statement 'keyword.viFilename' as 'stmt.vi_filename'
  parse
    result := createNode();
    consume();   -- 'viFilename'
    raw := current().text;
    setAttr(result, 'vi.value', substr(raw, 2, len(raw) - 2));
    consume();   -- string value
    expect('delimiter.semicolon');
  end
end

statement 'keyword.viCompanyName' as 'stmt.vi_companyname'
  parse
    result := createNode();
    consume();   -- 'viCompanyName'
    raw := current().text;
    setAttr(result, 'vi.value', substr(raw, 2, len(raw) - 2));
    consume();   -- string value
    expect('delimiter.semicolon');
  end
end

statement 'keyword.viCopyright' as 'stmt.vi_copyright'
  parse
    result := createNode();
    consume();   -- 'viCopyright'
    raw := current().text;
    setAttr(result, 'vi.value', substr(raw, 2, len(raw) - 2));
    consume();   -- string value
    expect('delimiter.semicolon');
  end
end

-- ---------------------------------------------------------------------------
-- HELPER FUNCTIONS
-- ---------------------------------------------------------------------------

-- Resolve a type text string (e.g. 'int') to its C++ IR type (e.g. 'int64_t').
function resolveType(typeText: string) -> string
  result := typeToIR(typeTextToKind(typeText));
end

-- Emit all statements inside a stmt.block node.
function emitBlock(blk: node)
  i := 0;
  while i < childCount(blk) do
    emitNode(getChild(blk, i));
    i := i + 1;
  end
end

-- ---------------------------------------------------------------------------
-- EXPR OVERRIDES — teach ExprToString about custom expression node kinds
-- ---------------------------------------------------------------------------

-- expr.negate is produced by the unary minus prefix handler.
-- ExprToString does not know this custom kind, so we override it here.
exproverride 'expr.negate'
  override
    result := '-' + exprToString(getChild(node, 0));
  end
end

-- ---------------------------------------------------------------------------
-- SEMANTIC RULES
-- ---------------------------------------------------------------------------

-- Program root: global scope
semantic 'program.root'
  pushScope('global', node);
  visitChildren(node);
  popScope(node);
end

-- Function declaration: push a scope, declare params, analyse body
semantic 'stmt.func_decl'
  declare(getAttr(node, 'func.name'), node);
  pushScope(getAttr(node, 'func.name'), node);
  -- visit param nodes (children before the body block)
  i := 0;
  while i < childCount(node) - 1 do
    visitNode(getChild(node, i));
    i := i + 1;
  end
  -- visit the body block (last child)
  visitNode(getChild(node, childCount(node) - 1));
  popScope(node);
end

-- Parameter declaration
semantic 'stmt.param'
  declare(getAttr(node, 'param.name'), node);
  setAttr(node, 'sem.type', typeTextToKind(getAttr(node, 'param.type_text')));
end

-- Variable declaration: declare in current scope, record type
semantic 'stmt.var_decl'
  ok := declare(getAttr(node, 'decl.name'), node);
  if not ok then
    error(node, 'ML001', 'Duplicate variable: ' + getAttr(node, 'decl.name'));
  end
  setAttr(node, 'sem.type', typeTextToKind(getAttr(node, 'decl.type_text')));
  visitChildren(node);
end

-- Assignment: check target is declared
semantic 'stmt.assign'
  sym := lookup(getAttr(node, 'assign.target'));
  if sym = nil then
    error(node, 'ML002', 'Undeclared variable: ' + getAttr(node, 'assign.target'));
  end
  visitChildren(node);
end

-- Identifier reference: check it is declared
semantic 'expr.ident'
  sym := lookup(getAttr(node, 'ident.name'));
  if sym = nil then
    error(node, 'ML003', 'Undeclared identifier: ' + getAttr(node, 'ident.name'));
  end
end

-- If statement
semantic 'stmt.if'
  visitChildren(node);
end

-- While statement
semantic 'stmt.while'
  visitChildren(node);
end

-- Block
semantic 'stmt.block'
  visitChildren(node);
end

-- Return statement
semantic 'stmt.return'
  visitChildren(node);
end

-- Print statement
semantic 'stmt.print'
  visitChildren(node);
end

-- Call expression: basic visit
semantic 'expr.call'
  visitChildren(node);
end

-- Expression statement wrapper
semantic 'stmt.expr_stmt'
  visitChildren(node);
end

-- ---------------------------------------------------------------------------
-- EMIT RULES
-- ---------------------------------------------------------------------------

-- Program root: configure pipeline, emit runtime includes, then main()
emit 'program.root'
  setPlatform('win64');
  setBuildMode('exe');
  setOptimize('debug');
  -- runtime includes
  include('cstdint',  target.header);
  include('cstdio',   target.header);
  include('cstring',  target.header);
  include('string',   target.header);
  -- emit top-level declarations (functions) first, then main body
  n := childCount(node);
  -- First pass: emit function declarations
  i := 0;
  while i < n do
    child := getChild(node, i);
    if nodeKind(child) = 'stmt.func_decl' then
      emitNode(child);
    end
    i := i + 1;
  end
  -- Second pass: emit everything else into main()
  func('main', 'int');
  i := 0;
  while i < n do
    child := getChild(node, i);
    if nodeKind(child) <> 'stmt.func_decl' then
      emitNode(child);
    end
    i := i + 1;
  end
  returnVal('0');
  endFunc();
end

-- Function declaration
emit 'stmt.func_decl'
  retTypeText := getAttr(node, 'func.return_type_text');
  retType     := resolveType(retTypeText);
  func(getAttr(node, 'func.name'), retType);
  -- emit parameters (all children except the last, which is the body)
  i := 0;
  while i < childCount(node) - 1 do
    p := getChild(node, i);
    param(getAttr(p, 'param.name'),
          resolveType(getAttr(p, 'param.type_text')));
    i := i + 1;
  end
  -- emit body block
  emitBlock(getChild(node, childCount(node) - 1));
  endFunc();
  blankLine();
end

-- Variable declaration
emit 'stmt.var_decl'
  declVar(getAttr(node, 'decl.name'),
          resolveType(getAttr(node, 'decl.type_text')),
          exprToString(getChild(node, 0)));
end

-- Assignment
emit 'stmt.assign'
  assign(getAttr(node, 'assign.target'),
         exprToString(getChild(node, 0)));
end

-- Expression statement wrapper (e.g. a bare function call)
emit 'stmt.expr_stmt'
  stmt(exprToString(getChild(node, 0)) + ';');
end

-- Pipeline configuration — source-level overrides for platform, buildmode, optimize, subsystem
emit 'stmt.set_platform'
  setPlatform(getAttr(node, 'pipeline.value'));
end

emit 'stmt.set_buildmode'
  setBuildMode(getAttr(node, 'pipeline.value'));
end

emit 'stmt.set_optimize'
  setOptimize(getAttr(node, 'pipeline.value'));
end

emit 'stmt.set_subsystem'
  setSubsystem(getAttr(node, 'pipeline.value'));
end

-- Version info emit rules

emit 'stmt.vi_enabled'
  viEnabled(getAttr(node, 'vi.value'));
end

emit 'stmt.vi_exeicon'
  viExeIcon(getAttr(node, 'vi.value'));
end

emit 'stmt.vi_major'
  viMajor(getAttr(node, 'vi.value'));
end

emit 'stmt.vi_minor'
  viMinor(getAttr(node, 'vi.value'));
end

emit 'stmt.vi_patch'
  viPatch(getAttr(node, 'vi.value'));
end

emit 'stmt.vi_productname'
  viProductName(getAttr(node, 'vi.value'));
end

emit 'stmt.vi_description'
  viDescription(getAttr(node, 'vi.value'));
end

emit 'stmt.vi_filename'
  viFilename(getAttr(node, 'vi.value'));
end

emit 'stmt.vi_companyname'
  viCompanyName(getAttr(node, 'vi.value'));
end

emit 'stmt.vi_copyright'
  viCopyright(getAttr(node, 'vi.value'));
end

-- print( expr ) — emits printf for int64_t, std::string, bool
emit 'stmt.print'
  val := exprToString(getChild(node, 0));
  stmt(invoke('printf', '"%lld\n"', '(long long)(' + val + ')') + ';');
end

-- if / else
emit 'stmt.if'
  cond := exprToString(getChild(node, 0));
  ifStmt(cond);
  emitBlock(getChild(node, 1));
  if childCount(node) > 2 then
    elseStmt();
    emitBlock(getChild(node, 2));
  end
  endIf();
end

-- while
emit 'stmt.while'
  cond := exprToString(getChild(node, 0));
  whileStmt(cond);
  emitBlock(getChild(node, 1));
  endWhile();
end

-- return
emit 'stmt.return'
  if childCount(node) > 0 then
    returnVal(exprToString(getChild(node, 0)));
  else
    returnVoid();
  end
end

-- Identifier reference
emit 'expr.ident'
  result := get(getAttr(node, 'ident.name'));
end

-- Function call expression
emit 'expr.call'
  fname := getAttr(node, 'call.name');
  -- build comma-separated arg list manually
  args := '';
  i := 0;
  while i < childCount(node) do
    if i > 0 then
      args := args + ', ';
    end
    args := args + exprToString(getChild(node, i));
    i := i + 1;
  end
  result := fname + '(' + args + ')';
end

-- Grouped expression
emit 'expr.grouped'
  result := '(' + exprToString(getChild(node, 0)) + ')';
end

-- Unary negation
emit 'expr.negate'
  result := neg(exprToString(getChild(node, 0)));
end

-- Boolean literal
emit 'expr.bool'
  result := getAttr(node, 'bool.value');
end

-- Nil literal
emit 'expr.nil'
  result := nullLit();
end

-- stmt.block (when emitted directly, e.g. by emitNode)
emit 'stmt.block'
  emitBlock(node);
end
